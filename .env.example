# PostgreSQL connection string used by the application and Alembic.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://gpr_user:gpr_password@localhost:5432/gpr_db

# Secret used to sign JWT access tokens. Generate a real one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-deploying

# Access token lifetime, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Algorithm used for JWT signing.
JWT_ALGORITHM=HS256

# Set to "true" to enable verbose SQL logging (useful when debugging queries).
SQL_ECHO=false
